{
  "functions": {
    "api/*.mjs": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/finance/:symbol", "destination": "/api/finance.js?symbol=:symbol" },
    { "source": "/api/deep-scrutiny", "destination": "/api/deep-scrutiny.mjs" },
    { "source": "/api/news-scrutiny", "destination": "/api/news-scrutiny.mjs" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
